#===============================================================
# Docker image
# Local image name and version tag used by 'make build'.
# Change the version when you rebuild after updating Alpine or gocryptfs.
#===============================================================
DOCKER_IMAGE_TAG_NAME="local/gocryptfs"
DOCKER_IMAGE_TAG_VERSION="1.0.0"

# Alpine Linux base image version used in the Dockerfile.
ALPINE_VERSION="3.23"

# gocryptfs release to install inside the Docker image.
GOCRYPTFS_VERSION="2.5"

#===============================================================
# SSH credentials
# The container uses these to authenticate to the remote backup server.
# Both paths must be absolute paths on the host.
#===============================================================

# Absolute path to the SSH private key on the host.
# Must have read permission for the user running Docker (chmod 600 recommended).
SSH_KEY_FILE="/home/youruser/.ssh/id_ed25519"

# Absolute path to the SSH known_hosts file on the host.
# Used to verify the remote server fingerprint and prevent MITM attacks.
# Run 'ssh-keyscan <remote-host> >> ~/.ssh/known_hosts' to add a new host.
SSH_KNOWN_HOSTS_FILE="/home/youruser/.ssh/known_hosts"

#===============================================================
# gocryptfs passkey
# File containing the passphrase used to encrypt/decrypt the backup.
# Keep this file safe: losing it means losing access to your backup.
# Not used when PARANOID_MODE=true (see below).
#===============================================================

# Absolute path to the passphrase file on the host.
# If the file does not exist, 'make backup' will prompt you to create it.
# Recommended: a hidden file with chmod 600 (e.g. ~/.gocrypt-passfile).
GOCRYPTFS_PASSKEY_FILE="/home/youruser/.gocrypt-passfile"

# When true, the passphrase is never stored on disk.
# gocryptfs will prompt for it interactively each time you run backup, restore, or view.
# GOCRYPTFS_PASSKEY_FILE is ignored when PARANOID_MODE=true.
# Requires an interactive terminal; cannot be used headlessly (e.g. cron jobs).
PARANOID_MODE=false

#===============================================================
# Backup source
# The local directory that will be encrypted and synced to the remote server.
#===============================================================

# Absolute path to the directory you want to back up (your home dir or any folder).
BACKUP_SOURCE_FOLDER="/home/youruser"

# Path where the gocryptfs reverse config is stored between runs (root backup only).
# gocryptfs writes this file on first init; subsequent runs reuse it to keep
# the same encrypted filenames. Set it to a path outside the backup source.
# Only needed for 'make backup_as_root'; user backup manages this automatically.
BACKUP_ENCRYPTION_CONF="/home/youruser/.gocryptfs.reverse.conf"

# rsync filter rules file (include/exclude patterns).
# Controls which files inside BACKUP_SOURCE_FOLDER are transferred.
# See conf/backup-filter-rules.txt for syntax and examples.
BACKUP_FILTER_RULES="./conf/backup-filter-rules.txt"

#===============================================================
# Remote server
# SSH destination where the encrypted backup is stored.
#===============================================================

# Remote server in 'user@host' format (hostname or IP address).
REMOTE_SERVER="user@192.168.1.100"

# Absolute path on the remote server where encrypted files will be stored.
# The directory must exist and be writable by REMOTE_SERVER's user.
REMOTE_SERVER_BACKUP_FOLDER="/mnt/backups/youruser"

#===============================================================
# Restore settings
# Used by 'make restore' and related targets.
#===============================================================

# Local directory where restored files are staged.
# Files are restored here for review before you move them back to their origin.
# The directory is created automatically if it does not exist.
RESTORE_DESTINATION="/tmp/restore"

# rsync exclude list for restore (patterns of files to skip during restore).
# See conf/restore-exclude-list.txt for syntax and examples.
RESTORE_EXCLUDE_LIST="./conf/restore-exclude-list.txt"

# File listing specific paths to restore (one relative path per line).
# Leave the file empty to restore everything. Supports glob patterns.
# Example line: Documents/invoices/
RESTORE_PATHS_FILE="./conf/restore-paths.txt"

#===============================================================
# rsync options
#===============================================================

# Maximum transfer rate in kbytes/s. Set to 0 for no limit.
# Example: 5000 limits to roughly 5 MB/s.
RSYNC_RATE_LIMIT=0

# Retry rsync automatically on transient failures (true/false).
# Useful on unstable connections: rsync will keep retrying with exponential
# backoff (up to 5 minutes between attempts) until a full sync completes.
RSYNC_LOOP=true

#===============================================================
# gocryptfs encryption settings
# These parameters are applied only on the very first 'make backup' run.
# After init, gocryptfs stores them in .gocryptfs.reverse.conf and they
# cannot be changed without re-initialising (which would break the backup).
#===============================================================

# Encrypt filenames on the remote server (true/false).
# true  -- filenames are scrambled; the remote server cannot see your directory structure
# false -- filenames are stored in plaintext; easier to restore individual files
#          without decrypting everything, but leaks names and paths to the server
# Note: changing this after the first init requires deleting .gocryptfs.reverse.conf
#       and re-running 'make backup' (this will re-encrypt the entire backup).
GOCRYPTFS_ENCRYPT_NAMES=false

# Encryption cipher used for the backup.
#   aes-gcm   -- AES-256-GCM (default, fastest on CPUs with AES hardware)
#   aes-siv   -- AES-SIV-512 (collision resistant, good for deduplicated storage)
#   xchacha   -- XChaCha20-Poly1305 (fast on CPUs without AES hardware)
GOCRYPTFS_CIPHER="aes-gcm"

# scrypt key derivation cost exponent: 2^N iterations.
# Higher values make the passphrase harder to brute-force but slower to mount.
# Default: 16 (65 536 iterations). Range: 10 (fast) to 20+ (very slow).
GOCRYPTFS_SCRYPT_N=16
